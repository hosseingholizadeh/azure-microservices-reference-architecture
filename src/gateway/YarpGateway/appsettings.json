{
  "ReverseProxy": {
    "Routes": {
      "catalog": {
        "ClusterId": "catalogCluster",
        "Match": { "Path": "/catalog/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalogCluster": {
        "Destinations": {
          "d1": { "Address": "http://catalogservice:5000/" }
        }
      }
    }
  }
}